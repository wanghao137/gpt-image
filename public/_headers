# Cloudflare Pages cache rules.
# Vite emits hashed filenames for /assets, so they're safe to cache forever.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Data JSON refreshed daily by the GH Action; revalidate on edge but show fast.
/data/cases.json
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/data/templates.json
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

# Per-case prompt fetches: never change for a given case id, hash it generously.
/data/prompts/*
  Cache-Control: public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800

/favicon.svg
  Cache-Control: public, max-age=86400

# SEO crawlers care about freshness for the index files — short edge cache.
/sitemap.xml
  Cache-Control: public, max-age=600, s-maxage=3600

/robots.txt
  Cache-Control: public, max-age=600, s-maxage=3600

# Static HTML — short cache so updates roll out fast on every deploy.
/
  Cache-Control: public, max-age=0, must-revalidate

/case/*
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/category/*
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/cases
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/templates
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/guide
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/services
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/about
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/agents
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Hidden admin entry — never cached at any layer, never indexed.
/admin
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

# Security headers (apply to everything)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
