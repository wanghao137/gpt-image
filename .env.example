# scripts/sync.mjs upstream sources for cases.json + style-library.json + images/.
# Each entry must point at the *directory* (not bare host), and trailing slashes
# are optional. Origins are tried in order; first success wins.
#
# Default (used when this var is empty): jsDelivr, then GitHub raw.
# Override examples:
#   DATA_ORIGINS=https://cdn.jsdelivr.net/gh/freestylefly/awesome-gpt-image-2@main/data
#   DATA_ORIGINS=https://raw.githubusercontent.com/freestylefly/awesome-gpt-image-2/main/data,https://cdn.jsdelivr.net/gh/freestylefly/awesome-gpt-image-2@main/data
# DATA_ORIGINS=

# Tencent Cloud COS — used by `scripts/upload-cos.mjs` and the public-runtime
# image URL builder (src/lib/img.ts). The bucket holds /uploads/* originals so
# they're served from a Hong Kong PoP at <100ms RTT for mainland-China users
# instead of via Cloudflare Pages free-tier (which routes through US/JP).
#
# COS_BUCKET — full bucket id with appid suffix (e.g. "gpt-image-2-1259488227")
# COS_REGION — bucket region (e.g. "ap-hongkong" for HK)
# COS_HOST   — public hostname; can be left blank to derive
#              `${COS_BUCKET}.cos.${COS_REGION}.myqcloud.com`. Set this if
#              you've bound a custom CDN domain to the bucket.
# COS_SECRET_ID  — sub-account SecretId (CAM user with QcloudCOSDataFullControl)
# COS_SECRET_KEY — sub-account SecretKey
#
# Only the public ones (COS_BUCKET, COS_REGION, COS_HOST) are referenced from
# the browser bundle; SecretId/SecretKey are read by the upload script ONLY.
#
# DO NOT commit real values. Copy this file to .env.local instead.
COS_BUCKET=
COS_REGION=
COS_HOST=
COS_SECRET_ID=
COS_SECRET_KEY=

# Public-side mirror of the COS host — exposed to the browser via Vite's
# `VITE_` prefix convention so the URL builder can construct hot-loaded
# image URLs at runtime / SSG without leaking secrets. Set this to the
# same value as COS_HOST (or leave blank to derive from VITE_COS_BUCKET +
# VITE_COS_REGION).
VITE_COS_BUCKET=
VITE_COS_REGION=
VITE_COS_HOST=

# Hermes server-to-server admin API.
#
# These values are used by `api/hermes/content.js` on Vercel only. Do not add
# them to client-side VITE_* variables and do not commit real values.
#
# HERMES_ADMIN_API_KEY — shared secret Hermes sends as `Authorization: Bearer ...`
# HERMES_GITHUB_TOKEN  — fine-grained GitHub token with Contents read/write for this repo
# HERMES_REPO_OWNER    — defaults to wanghao137
# HERMES_REPO_NAME     — defaults to gpt-image
# HERMES_REPO_BRANCH   — defaults to main
HERMES_ADMIN_API_KEY=
HERMES_GITHUB_TOKEN=
HERMES_REPO_OWNER=
HERMES_REPO_NAME=
HERMES_REPO_BRANCH=
