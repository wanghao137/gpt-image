node_modules
dist
.DS_Store
*.local
.env
.claude/
.vscode/
tsconfig.tsbuildinfo
src/data/

# Image pipeline cache. The cache is keyed by source URL hash and stores
# raw (un-resized) bytes so repeat builds skip the network entirely. It
# lives under node_modules/ which is already gitignored — this entry is
# explicit for clarity / IDEs that hide node_modules.
node_modules/.image-cache/

# IMPORTANT: public/images/ IS NOT IGNORED. Those are the optimised JPEGs
# that ship with the deploy and replace runtime image fetching. Committing
# them keeps CF Pages CI builds fast (<2min vs ~10min if regenerated each
# time) and matches the strategy the reference site uses.
.vercel

# Binary archives don't belong in version control — the unpacked sources
# (e.g. docs/hermes/) are tracked instead. Keeping the zip out avoids repo
# bloat and noisy binary diffs.
*.zip

# Throwaway investigation / probe artifacts. These are generated ad-hoc while
# debugging classifiers, sizes, etc. and should never be committed.
/classify-*.txt
/scripts/_*.mjs

# Playwright MCP browser-testing scratch output.
.playwright-mcp/
.omx/
test-results/

.env.local
